{
  "name": "mixi2-js",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript SDK for mixi2 Application API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "proto"
  ],
  "scripts": {
    "setup": "npm install && node scripts/setup.js",
    "test": "jest",
    "check": "tsc --noEmit",
    "lint": "eslint ./src/",
    "lint:fix": "eslint ./src/ --fix",
    "build": "tsup",
    "format": "prettier --write ./src/",
    "format:check": "prettier --check ./src/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otoneko1102/mixi2-js.git"
  },
  "keywords": [
    "mixi2",
    "mixi",
    "mixi.social",
    "sdk",
    "api",
    "grpc",
    "webhook",
    "bot"
  ],
  "author": "otoneko.",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/otoneko1102/mixi2-js/issues"
  },
  "homepage": "https://github.com/otoneko1102/mixi2-js#readme",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
